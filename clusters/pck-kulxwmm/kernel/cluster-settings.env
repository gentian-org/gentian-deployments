# Cluster-scoped non-secret settings consumed by gentian-os installer/update.
# This file is intentionally shell-style so install.sh can source it directly.

# Identity / URL topology
KERNEL_DOMAIN=gentian.cloud
TENANCY_MODE=multi

# Exposure model
NETWORK_MODE=static-ip
NODE_IP=179.237.72.106  

# Mail behavior
MAIL_SERVICE_MODE=kernel

# Credential strategy
SECRET_MODE=derived

# App bootstrap endpoints
MINIO_ENDPOINT=http://minio-dev.gentian-infra-dev.svc.cluster.local:9000
CNPG_HOST=postgres-rw.platform-kernel.svc.cluster.local

# Cluster default storage class
STORAGE_CLASS=csi-cinder-sc-retain
