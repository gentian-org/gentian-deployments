# Cluster-scoped non-secret settings consumed by gentian-os installer/update.
# Homelab bare-metal K8s — exposed via Cloudflare tunnel (see kernel/values.yaml).
#
# KERNEL_DOMAIN is NOT set here — it lives solely in
# clusters/test/kernel/claims/cluster.yaml (scaffolded by install.sh on first
# bootstrap; see gentian-os/docs/deployment.md §1). install.sh/update.sh read
# it from there via resolve_kernel_domain_from_claim.

# Nubus LDAP naming context (must match ldap.base in kernel/values.yaml).
LDAP_BASE_DN=dc=swp-ldap,dc=internal

# Identity / URL topology
TENANCY_MODE=multi

# Exposure model (Cloudflare tunnel — NODE_IP not required)
NETWORK_MODE=tunnel

# Edge routing stack (must match operator Helm routingMode)
ROUTING_MODE=gateway

# Mail behavior
MAIL_SERVICE_MODE=external
# Postfix relay endpoints (non-secret; credentials in install.secrets.env)
EXTERNAL_SMTP_HOST=smtp.gmail.com
EXTERNAL_SMTP_PORT=587
EXTERNAL_SMTP_SSL=false
EXTERNAL_SMTP_STARTTLS=true

# Credential strategy
SECRET_MODE=derived

# App bootstrap endpoints
MINIO_ENDPOINT=http://minio-dev.gentian-infra-dev.svc.cluster.local:9000
CNPG_HOST=postgres-rw.platform-kernel.svc.cluster.local

# Cluster default storage class (homelab bare metal)
STORAGE_CLASS=nfs-csi

# Tenant namespace resource defaults (written to gentian-cluster-config; consumed by
# tenant-default and app-default Crossplane compositions). Use lower values on
# resource-constrained homelab clusters; omit or raise on production CSP clusters.
TENANT_LIMITRANGE_DEFAULT_CPU=250m
TENANT_LIMITRANGE_DEFAULT_MEMORY=256Mi
TENANT_LIMITRANGE_DEFAULT_REQUEST_CPU=50m
TENANT_LIMITRANGE_DEFAULT_REQUEST_MEMORY=128Mi
TENANT_INITJOB_LIMIT_CPU=200m
TENANT_INITJOB_LIMIT_MEMORY=256Mi
TENANT_INITJOB_REQUEST_CPU=50m
TENANT_INITJOB_REQUEST_MEMORY=128Mi
