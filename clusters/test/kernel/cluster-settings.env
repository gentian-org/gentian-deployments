# Cluster-scoped non-secret settings consumed by gentian-os installer/update.
# Baseline snapshot from pre-refactor deployment layout.

KERNEL_DOMAIN=desk.gentian.org
TENANCY_MODE=multi
NETWORK_MODE=tunnel
MAIL_SERVICE_MODE=external
SECRET_MODE=derived
MINIO_ENDPOINT=http://minio-dev.gentian-infra-dev.svc.cluster.local:9000
CNPG_HOST=postgres-rw.platform-kernel.svc.cluster.local
STORAGE_CLASS=nfs-csi
