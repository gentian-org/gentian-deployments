# Gentian OS — per-cluster runtime settings template
#
# Usage:
#   cp cluster-settings.env.template \
#     ${GENTIAN_DEPLOYMENTS_PATH}/clusters/<cluster>/kernel/cluster-settings.env
#   edit it
#   ./install.sh
#
# Unlike install.env.template / install.secrets.env.template (which live and
# stay in this repo), this file's destination is gentian-deployments — one
# real, checked-in copy per cluster at
# clusters/<cluster>/kernel/cluster-settings.env. It's the one file in that
# directory install.sh never generates or overwrites (see
# gentian-os/docs/deployment.md §3): everything else under kernel/ is either
# scaffolded from KERNEL_DOMAIN/GENTIAN_DEPLOYMENTS_STAGE or rendered fresh
# from a template in gentian-os, but network mode, storage class, and mail
# config aren't derivable from those two inputs, so a human has to state them.
#
# Not here: KERNEL_DOMAIN. It has exactly one authored copy — the cluster's
# Crossplane Claim (clusters/<cluster>/kernel/claims/cluster.yaml) — scaffolded
# on first bootstrap from what you type at the KERNEL_DOMAIN prompt (or the
# KERNEL_DOMAIN env var, if already set). See docs/deployment.md §1.

# -----------------------------------------------------------------------------
# Identity / URL topology
# -----------------------------------------------------------------------------
# multi   — each tenant gets its own subdomain (<tenant>.KERNEL_DOMAIN) and
#           Keycloak realm (the common case).
# single  — one tenant occupies the whole cluster at KERNEL_DOMAIN directly.
TENANCY_MODE=multi

# -----------------------------------------------------------------------------
# Exposure model
# -----------------------------------------------------------------------------
# tunnel     (default) — cluster sits behind a reverse-proxy/tunnel (e.g.
#              Cloudflare Tunnel); DNS resolves to the tunnel endpoint.
#              NODE_IP is not required.
# static-ip  — node has a public/reachable static IP; DNS points directly at
#              NODE_IP, which becomes required below.
NETWORK_MODE=tunnel

# Required only when NETWORK_MODE=static-ip. Auto-detected from the cluster
# when unset in tunnel mode.
# NODE_IP=203.0.113.10

# -----------------------------------------------------------------------------
# Edge routing
# -----------------------------------------------------------------------------
# gateway is the only supported value (Envoy Gateway + Gateway API). Must
# match the operator's Helm routingMode value.
ROUTING_MODE=gateway

# -----------------------------------------------------------------------------
# Mail behavior
# -----------------------------------------------------------------------------
# external (default) — relay invitation/reset mail through an external SMTP
#            provider (e.g. Gmail, SES). Needs EXTERNAL_SMTP_* below, plus
#            SMTP_RELAY_USERNAME/SMTP_RELAY_PASSWORD in install.secrets.env.
# kernel     — use in-cluster Postfix/Dovecot. Needs NETWORK_MODE=static-ip
#            (kernel mail needs a reachable SMTP ingress; incompatible with
#            NETWORK_MODE=tunnel).
MAIL_SERVICE_MODE=external

# Required when MAIL_SERVICE_MODE=external. No default — must be set.
EXTERNAL_SMTP_HOST=smtp.gmail.com
# Optional — defaults shown.
EXTERNAL_SMTP_PORT=587
EXTERNAL_SMTP_SSL=false
EXTERNAL_SMTP_STARTTLS=true

# -----------------------------------------------------------------------------
# Credential strategy
# -----------------------------------------------------------------------------
# derived (default) — every app/service secret is HKDF-derived from
#            MASTER_PASSWORD (install.secrets.env); reproducible, no OpenBao
#            writes needed to rotate a whole cluster from one master secret.
# random     — each secret is independently random, generated once and
#            stored in OpenBao. No cross-cluster reproducibility.
SECRET_MODE=derived

# -----------------------------------------------------------------------------
# App bootstrap endpoints (optional — sane per-stage defaults, override only
# if this cluster's infra tier deviates from the standard naming)
# -----------------------------------------------------------------------------
# Defaults to http://minio-<stage>.gentian-infra-<stage>.svc.cluster.local:9000
# MINIO_ENDPOINT=http://minio-dev.gentian-infra-dev.svc.cluster.local:9000
# Defaults to <cnpg-cluster>-rw.platform-kernel.svc.cluster.local
# CNPG_HOST=postgres-rw.platform-kernel.svc.cluster.local

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Cluster default StorageClass. Leave unset to use the cluster's own default
# StorageClass (annotated storageclass.kubernetes.io/is-default-class).
STORAGE_CLASS=nfs-csi

# -----------------------------------------------------------------------------
# LLM serving (only used when GPU_ACCELERATION=true — see install.env)
# -----------------------------------------------------------------------------
# beefy1: single 24GB card, 4-way time-sliced (see gpu-sharing.yaml in
# gentian-os) — stay well under 1.0 utilization so this pod doesn't
# starve/OOM its neighbors.
VLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=8192
VLLM_MODEL_CACHE_SIZE=60Gi
# Pinned to a specific stable release instead of :latest — the repeated
# ImagePullBackOff (corrupted layer, same digest across multiple pulls and
# node-level cache purges) only ever hit :latest; pinning gets a different,
# content-verified manifest/layer set and reproducible pulls going forward.
VLLM_IMAGE_TAG=v0.25.1

# -----------------------------------------------------------------------------
# Tenant namespace resource defaults (optional — defaults shown below).
# Written to gentian-cluster-config; consumed by the tenant-default and
# app-default Crossplane compositions. Lower these on resource-constrained
# homelab clusters; raise or omit on production-class clusters.
# -----------------------------------------------------------------------------
TENANT_LIMITRANGE_DEFAULT_CPU=500m
TENANT_LIMITRANGE_DEFAULT_MEMORY=512Mi
TENANT_LIMITRANGE_DEFAULT_REQUEST_CPU=100m
TENANT_LIMITRANGE_DEFAULT_REQUEST_MEMORY=128Mi
TENANT_INITJOB_LIMIT_CPU=500m
TENANT_INITJOB_LIMIT_MEMORY=512Mi
TENANT_INITJOB_REQUEST_CPU=100m
TENANT_INITJOB_REQUEST_MEMORY=128Mi
